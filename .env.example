# ===========================================
# 环境变量配置模板 - 请复制为 .env 或 xiaoxin.env 并填入真实值
# ===========================================

# 阿里云 DashScope API（通义千问等）
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# Azure 语音服务（可选）
# Azure_Whisper_API_KEY=
# Azure_Whisper_API_Url=https://eastus.api.cognitive.microsoft.com/
# Azure_speech_key=
# Azure_speech_region=centralus
# Azure_speech_speaker=longwan

# 讯飞开放平台（指尖单词 OCR）
# XFYUN_APP_ID=
# XFYUN_API_KEY=
# XFYUN_API_SECRET=

# 腾讯云（语音评测等）
# TENCENT_SECRET_ID=
# TENCENT_SECRET_KEY=
# TENCENT_REGION=ap-shanghai

# 数据库配置（可选）
# DATABASE_HOST=localhost
# DATABASE_PORT=3306
# DATABASE_USER=root
# DATABASE_PASSWORD=your_password

# 唤醒词配置
# WakeupWord=你好广和通
# WakeupModelFile=wakeword.table
